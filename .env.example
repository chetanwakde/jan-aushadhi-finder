# ─────────────────────────────────────────────────────────────────────────────
# Jan Aushadhi Finder — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ── Security ─────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_THIS_TO_A_RANDOM_64_CHAR_HEX_STRING

# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=https://yourapp.com,https://www.yourapp.com

# ── Database (choose one) ────────────────────────────────────────────────────

# Option A: PostgreSQL (recommended for production)
DATABASE_URL=postgresql://user:password@localhost:5432/jan_aushadhi

# Option B: MongoDB
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/jan_aushadhi

# Option C: Supabase (PostgreSQL-as-a-Service)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── SMS / OTP Provider ───────────────────────────────────────────────────────
# Option A: MSG91 (India)
MSG91_AUTH_KEY=your-msg91-auth-key
MSG91_SENDER_ID=JANAUS
MSG91_TEMPLATE_ID=your-template-id

# Option B: Twilio
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# ── Google OAuth & Maps ───────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=https://yourapp.com/api/auth/google/callback
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# ── Push Notifications (VAPID) ────────────────────────────────────────────────
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_EMAIL=mailto:admin@yourapp.com

# ── Firebase Cloud Messaging (alternative to VAPID) ──────────────────────────
FCM_SERVER_KEY=your-fcm-server-key

# ── Redis (for rate limiting & session storage in production) ─────────────────
REDIS_URL=redis://localhost:6379

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info
# Options: error | warn | info | http | verbose | debug | silly

# ── Analytics (optional) ──────────────────────────────────────────────────────
GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX

# ── Admin ─────────────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@yourapp.com
# First user registered with this email gets admin role automatically
